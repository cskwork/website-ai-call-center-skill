{
  "name": "website-ai-call-center-skill",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Framework-agnostic AI call-center overlay template with browser WASM STT/TTS adapters and minimal infrastructure.",
  "scripts": {
    "build": "vite build && vite build --config vite.workers.config.mjs",
    "dev": "vite --host 127.0.0.1",
    "prepack": "npm run build",
    "test": "node --test tests/*.test.mjs && npm run validate",
    "validate": "node scripts/validate.mjs",
    "smoke:browser": "node scripts/browser-smoke.mjs",
    "site:build": "npm run build && node scripts/build-pages.mjs",
    "smoke:site": "node scripts/site-smoke.mjs"
  },
  "files": [
    "dist/",
    "docs/",
    "examples/",
    "skills/",
    "src/",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "codex-skill",
    "ai-call-center",
    "wasm-stt",
    "wasm-tts",
    "browser-ai",
    "framework-agnostic",
    "technical-support",
    "website-overlay"
  ],
  "license": "MIT",
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@mintplex-labs/piper-tts-web": "^1.0.4",
    "onnxruntime-web": "^1.26.0"
  },
  "devDependencies": {
    "playwright": "^1.47.0",
    "vite": "^8.0.14"
  },
  "main": "./dist/website-ai-call-center.iife.js",
  "module": "./dist/website-ai-call-center.esm.js",
  "exports": {
    ".": {
      "import": "./dist/website-ai-call-center.esm.js",
      "default": "./dist/website-ai-call-center.iife.js"
    }
  }
}
