{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cskwork.github.io/website-ai-call-center-skill/schemas/call-scenario.schema.json",
  "title": "Website AI call-center scenario",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "scenario_intent",
    "title",
    "button_label",
    "summary",
    "utterances",
    "match",
    "reply",
    "frontend_actions",
    "workflow"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "catalog_order": {
      "type": "integer",
      "minimum": 0
    },
    "scenario_intent": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "button_label": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "utterances": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "required": ["keywords"],
      "properties": {
        "keywords": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          }
        }
      }
    },
    "reply": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "frontend_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issue_type"],
      "properties": {
        "issue_type": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "handoff": {
          "type": "boolean"
        }
      }
    }
  }
}
